            const feedback = document.getElementById('feedback6');
            
            const lcd = lcm(problemStates.p6.den1, problemStates.p6.den2);
            const newNum1 = problemStates.p6.num1 * (lcd / problemStates.p6.den1);
            const newNum2 = problemStates.p6.num2 * (lcd / problemStates.p6.den2);
            const resultNum = newNum1 + newNum2;
            const reduced = reduceFraction(resultNum, lcd);
            
            const userReduced = reduceFraction(userNum, userDen);
            
            if (userReduced.num === reduced.num && userReduced.den === reduced.den) {
                feedback.className = 'feedback correct';
                feedback.innerHTML = '🎉 Outstanding! You found the LCD and added correctly!';
                recordAnswer(true);
            } else {
                feedback.className = 'feedback incorrect';
                const lcd = lcm(problemStates.p6.den1, problemStates.p6.den2);
                feedback.innerHTML = `💡 Hint: Find the LCD of ${problemStates.p6.den1} and ${problemStates.p6.den2}. The LCD is ${lcd}. Convert both fractions to have denominator ${lcd}, then add the numerators.`;
                recordAnswer(false);
            }
        }
        
        // Initialize
        randomizeProblem1();
        randomizeProblem2();
        randomizeProblem3();
        randomizeProblem4();
        randomizeProblem5();
        randomizeProblem6();
    </script>
