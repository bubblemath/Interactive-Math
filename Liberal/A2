                currentStreak = 0;
                totalIncorrect++;
            }
            updateStreakDisplay();
        }
        
        function gcd(a, b) {
            a = Math.abs(a);
            b = Math.abs(b);
            while (b !== 0) {
                let temp = b;
                b = a % b;
                a = temp;
            }
            return a;
        }
        
        function lcm(a, b) {
            return Math.abs(a * b) / gcd(a, b);
        }
        
        function reduceFraction(num, den) {
            const divisor = gcd(num, den);
            return { num: num / divisor, den: den / divisor };
        }
        
        function getRandomInt(min, max) {
            return Math.floor(Math.random() * (max - min + 1)) + min;
        }
        
        function makeFrac(num, den) {
            return `<span class="frac"><span class="top">${num}</span><span class="bottom">${den}</span></span>`;
        }
        
        // Build Your Own Function
        function buildFractionModel() {
            const num1 = parseInt(document.getElementById('build-num1').value);
            const den1 = parseInt(document.getElementById('build-den1').value);
            const num2 = parseInt(document.getElementById('build-num2').value);
            const den2 = parseInt(document.getElementById('build-den2').value);
            const operation = document.getElementById('build-operation').value;
            
            const workspace = document.getElementById('build-workspace');
            
            if (num1 > den1 || num2 > den2) {
                workspace.innerHTML = '<p style="text-align: center; color: #dc3545; font-size: 1.2em;">Please use proper fractions (numerator ≤ denominator) for visual models!</p>';
                return;
            }
            
            if (operation === 'multiply') {
                buildMultiplyModel(num1, den1, num2, den2, workspace);
            } else if (operation === 'divide') {
                buildDivideModel(num1, den1, num2, den2, workspace);
            } else if (operation === 'add') {
                buildAddModel(num1, den1, num2, den2, workspace);
            } else if (operation === 'subtract') {
                buildSubtractModel(num1, den1, num2, den2, workspace);
            } else if (operation === 'reduce') {
                buildReduceModel(num1, den1, workspace);
            }
        }
        
        function buildMultiplyModel(num1, den1, num2, den2, workspace) {
            const resultNum = num1 * num2;
            const resultDen = den1 * den2;
            const reduced = reduceFraction(resultNum, resultDen);
            
            let html = `
                <h3 style="color: #667eea; text-align: center; margin-bottom: 20px;">
                    Building: ${makeFrac(num1, den1)} × ${makeFrac(num2, den2)}
                </h3>
                
                <div class="step-indicator">
                    Step 1: Start with ${makeFrac(num2, den2)} - Click to shade ${num2} out of ${den2} parts
                </div>
                
                <div style="text-align: center;">
                    <div class="interactive-grid">
                        <div class="grid-label">First Fraction: ${makeFrac(num2, den2)}</div>
                        <div class="area-grid" style="grid-template-columns: repeat(${den2}, 1fr);" id="grid1">
            `;
            
            for (let i = 0; i < den2; i++) {
                const isShaded = i < num2;
                html += `<div class="area-cell ${isShaded ? 'shaded' : 'unshaded'}" onclick="toggleCell(this)">${i + 1}</div>`;
            }
            
            html += `
                        </div>
                    </div>
                </div>
                
                <div class="step-indicator" style="margin-top: 30px;">
                    Step 2: Take ${makeFrac(num1, den1)} of those shaded parts - Divide each part into ${den1} rows and shade ${num1} rows
                </div>
                
                <div style="text-align: center;">
                    <div class="interactive-grid">
                        <div class="grid-label">Multiply: ${makeFrac(num1, den1)} of ${makeFrac(num2, den2)}</div>
                        <div class="area-grid" style="grid-template-columns: repeat(${den2}, 1fr);">
            `;
            
            for (let col = 0; col < den2; col++) {
                html += '<div style="display: grid; grid-template-rows: repeat(' + den1 + ', 1fr); gap: 1px;">';
                for (let row = 0; row < den1; row++) {
                    const isInOriginalShaded = col < num2;
                    const isInMultipliedShaded = row < num1;
                    const cellClass = (isInOriginalShaded && isInMultipliedShaded) ? 'multiply-overlap' : 'unshaded';
                    html += `<div class="area-cell ${cellClass}" style="height: ${Math.max(30, 300/den1)}px;" onclick="toggleCell(this)"></div>`;
                }
                html += '</div>';
            }
            
            html += `
                        </div>
                    </div>
                </div>
                
                <div class="step-indicator" style="margin-top: 30px;">
                    Step 3: Count the green squares!
                </div>
                
                <div class="result-box">
                    Green squares: ${resultNum}<br>
                    Total squares: ${resultDen}<br>
                    Result: ${makeFrac(resultNum, resultDen)} = ${makeFrac(reduced.num, reduced.den)}
                </div>
                
                <div class="why-box">
                    <h4>💡 What You Discovered:</h4>
                    <p><strong>Numerators multiply:</strong> ${num1} × ${num2} = ${resultNum}</p>
                    <p><strong>Denominators multiply:</strong> ${den1} × ${den2} = ${resultDen}</p>
                    <p>This is why ${makeFrac(num1, den1)} × ${makeFrac(num2, den2)} = ${makeFrac(resultNum, resultDen)} = ${makeFrac(reduced.num, reduced.den)}</p>
                </div>
            `;
            
            workspace.innerHTML = html;
        }
        
        function buildDivideModel(num1, den1, num2, den2, workspace) {
            const resultNum = num1 * den2;
            const resultDen = den1 * num2;
            const reduced = reduceFraction(resultNum, resultDen);
            
            let html = `
                <h3 style="color: #667eea; text-align: center; margin-bottom: 20px;">
                    Building: ${makeFrac(num1, den1)} ÷ ${makeFrac(num2, den2)}
                </h3>
                
                <div class="step-indicator">
                    Step 1: Keep the first fraction - ${makeFrac(num1, den1)}
                </div>
                
                <div style="text-align: center;">
                    <div class="interactive-grid">
                        <div class="grid-label">First Fraction: ${makeFrac(num1, den1)}</div>
                        <div class="area-grid" style="grid-template-columns: repeat(${den1}, 1fr);">
            `;
            
            for (let i = 0; i < den1; i++) {
                const isShaded = i < num1;
                html += `<div class="area-cell ${isShaded ? 'shaded' : 'unshaded'}" onclick="toggleCell(this)">${i + 1}</div>`;
            }
            
            html += `
                        </div>
                    </div>
                </div>
                
                <div class="step-indicator" style="margin-top: 30px;">
                    Step 2: Change ÷ to × and Flip ${makeFrac(num2, den2)} to ${makeFrac(den2, num2)}
                </div>
                
                <div style="text-align: center; font-size: 1.5em; margin: 20px 0;">
                    ${makeFrac(num1, den1)} × ${makeFrac(den2, num2)}
                </div>
                
                <div class="step-indicator">
                    Step 3: Now multiply!
                </div>
                
                <div class="result-box">
                    ${num1} × ${den2} = ${resultNum}<br>
                    ${den1} × ${num2} = ${resultDen}<br>
                    Result: ${makeFrac(resultNum, resultDen)} = ${makeFrac(reduced.num, reduced.den)}
                </div>
                
                <div class="why-box">
                    <h4>💡 What You Discovered:</h4>
                    <p><strong>Keep, Change, Flip:</strong> Division becomes multiplication by the reciprocal!</p>
                    <p>${makeFrac(num1, den1)} ÷ ${makeFrac(num2, den2)} = ${makeFrac(num1, den1)} × ${makeFrac(den2, num2)} = ${makeFrac(reduced.num, reduced.den)}</p>
                </div>
            `;
            
            workspace.innerHTML = html;
        }
        
        function buildAddModel(num1, den1, num2, den2, workspace) {
            if (den1 === den2) {
                // Same denominator
                const resultNum = num1 + num2;
                const reduced = reduceFraction(resultNum, den1);
                
                let html = `
                    <h3 style="color: #667eea; text-align: center; margin-bottom: 20px;">
                        Building: ${makeFrac(num1, den1)} + ${makeFrac(num2, den2)}
                    </h3>
                    
                    <div class="step-indicator">
                        Same denominator! Just add the numerators and keep the denominator.
                    </div>
                    
                    <div style="display: flex; justify-content: center; gap: 30px; margin: 30px 0;">
                        <div class="interactive-grid">
                            <div class="grid-label">${makeFrac(num1, den1)}</div>
                            <div class="area-grid" style="grid-template-columns: repeat(${den1}, 1fr);">
                `;
                
                for (let i = 0; i < den1; i++) {
                    const isShaded = i < num1;
                    html += `<div class="area-cell ${isShaded ? 'shaded' : 'unshaded'}" onclick="toggleCell(this)">${i + 1}</div>`;
                }
                
                html += `
                            </div>
                        </div>
                        
                        <div style="font-size: 3em; align-self: center;">+</div>
                        
                        <div class="interactive-grid">
                            <div class="grid-label">${makeFrac(num2, den2)}</div>
                            <div class="area-grid" style="grid-template-columns: repeat(${den2}, 1fr);">
                `;
                
                for (let i = 0; i < den2; i++) {
                    const isShaded = i < num2;
                    html += `<div class="area-cell ${isShaded ? 'multiply-overlap' : 'unshaded'}" onclick="toggleCell(this)">${i + 1}</div>`;
                }
                
                html += `
                            </div>
                        </div>
                    </div>
                    
                    <div class="result-box">
                        ${num1} + ${num2} = ${resultNum}<br>
                        Keep denominator: ${den1}<br>
                        Result: ${makeFrac(resultNum, den1)} = ${makeFrac(reduced.num, reduced.den)}
                    </div>
                `;
                
                workspace.innerHTML = html;
            } else {
                // Different denominators
                const lcd = lcm(den1, den2);
                const newNum1 = num1 * (lcd / den1);
                const newNum2 = num2 * (lcd / den2);
                const resultNum = newNum1 + newNum2;
                const reduced = reduceFraction(resultNum, lcd);
                
                let html = `
                    <h3 style="color: #667eea; text-align: center; margin-bottom: 20px;">
                        Building: ${makeFrac(num1, den1)} + ${makeFrac(num2, den2)}
                    </h3>
                    
                    <div class="step-indicator">
                        Step 1: Different denominators! Find LCD = ${lcd}
                    </div>
                    
                    <div class="step-indicator">
                        Step 2: Convert to equivalent fractions with LCD
                    </div>
                    
                    <div style="text-align: center; font-size: 1.3em; margin: 20px 0;">
                        ${makeFrac(num1, den1)} = ${makeFrac(newNum1, lcd)} and ${makeFrac(num2, den2)} = ${makeFrac(newNum2, lcd)}
                    </div>
                    
                    <div style="display: flex; justify-content: center; gap: 30px; margin: 30px 0;">
                        <div class="interactive-grid">
                            <div class="grid-label">${makeFrac(newNum1, lcd)}</div>
                            <div class="area-grid" style="grid-template-columns: repeat(${Math.min(lcd, 12)}, 1fr);">
                `;
                
                for (let i = 0; i < lcd; i++) {
                    const isShaded = i < newNum1;
                    html += `<div class="area-cell ${isShaded ? 'shaded' : 'unshaded'}" onclick="toggleCell(this)" style="width: 35px; height: 35px;"></div>`;
                }
                
                html += `
                            </div>
                        </div>
                        
                        <div style="font-size: 3em; align-self: center;">+</div>
                        
                        <div class="interactive-grid">
                            <div class="grid-label">${makeFrac(newNum2, lcd)}</div>
                            <div class="area-grid" style="grid-template-columns: repeat(${Math.min(lcd, 12)}, 1fr);">
                `;
                
                for (let i = 0; i < lcd; i++) {
                    const isShaded = i < newNum2;
                    html += `<div class="area-cell ${isShaded ? 'multiply-overlap' : 'unshaded'}" onclick="toggleCell(this)" style="width: 35px; height: 35px;"></div>`;
                }
                
                html += `
                            </div>
                        </div>
                    </div>
                    
                    <div class="result-box">
                        ${newNum1} + ${newNum2} = ${resultNum}<br>
                        Keep denominator: ${lcd}<br>
                        Result: ${makeFrac(resultNum, lcd)} = ${makeFrac(reduced.num, reduced.den)}
                    </div>
                    
                    <div class="why-box">
                        <h4>💡 What You Discovered:</h4>
                        <p>You can only add fractions when they have the same-sized pieces!</p>
                        <p>Finding the LCD makes all pieces equal so we can count them together.</p>
                    </div>
                `;
                
                workspace.innerHTML = html;
            }
        }
        
        function buildSubtractModel(num1, den1, num2, den2, workspace) {
            if (den1 === den2 && num1 >= num2) {
                const resultNum = num1 - num2;
                const reduced = reduceFraction(resultNum, den1);
                
                let html = `
                    <h3 style="color: #667eea; text-align: center; margin-bottom: 20px;">
                        Building: ${makeFrac(num1, den1)} − ${makeFrac(num2, den2)}
                    </h3>
                    
                    <div class="step-indicator">
                        Same denominator! Subtract the numerators and keep the denominator.
                    </div>
                    
                    <div style="text-align: center;">
                        <div class="interactive-grid">
                            <div class="grid-label">Start with ${makeFrac(num1, den1)}</div>
                            <div class="area-grid" style="grid-template-columns: repeat(${den1}, 1fr);">
                `;
                
                for (let i = 0; i < den1; i++) {
                    const isShaded = i < num1;
                    html += `<div class="area-cell ${isShaded ? 'shaded' : 'unshaded'}" onclick="toggleCell(this)">${i + 1}</div>`;
                }
                
                html += `
                            </div>
                        </div>
                        
                        <div style="font-size: 2em; margin: 20px 0;">Remove ${num2} parts ↓</div>
                        
                        <div class="interactive-grid">
                            <div class="grid-label">After removing ${makeFrac(num2, den2)}</div>
                            <div class="area-grid" style="grid-template-columns: repeat(${den1}, 1fr);">
                `;
                
                for (let i = 0; i < den1; i++) {
                    const isShaded = i < resultNum;
                    html += `<div class="area-cell ${isShaded ? 'multiply-overlap' : 'unshaded'}" onclick="toggleCell(this)">${i + 1}</div>`;
                }
                
                html += `
                            </div>
                        </div>
                    </div>
                    
                    <div class="result-box">
                        ${num1} − ${num2} = ${resultNum}<br>
                        Keep denominator: ${den1}<br>
                        Result: ${makeFrac(resultNum, den1)} = ${makeFrac(reduced.num, reduced.den)}
                    </div>
                `;
                
                workspace.innerHTML = html;
            } else {
                workspace.innerHTML = '<p style="text-align: center; color: #dc3545; font-size: 1.2em;">For subtraction, please use fractions with the same denominator and ensure the first numerator is larger!</p>';
            }
        }
        
        function buildReduceModel(num1, den1, workspace) {
            const g = gcd(num1, den1);
            const reduced = reduceFraction(num1, den1);
            
            let html = `
                <h3 style="color: #667eea; text-align: center; margin-bottom: 20px;">
                    Building: Reduce ${makeFrac(num1, den1)}
                </h3>
                
                <div class="step-indicator">
                    Step 1: Show ${makeFrac(num1, den1)} - Click to shade ${num1} out of ${den1} parts
                </div>
                
                <div style="text-align: center;">
                    <div class="interactive-grid">
                        <div class="grid-label">Original: ${makeFrac(num1, den1)}</div>
                        <div class="area-grid" style="grid-template-columns: repeat(${Math.min(den1, 12)}, 1fr);">
            `;
            
            for (let i = 0; i < den1; i++) {
                const isShaded = i < num1;
                html += `<div class="area-cell ${isShaded ? 'shaded' : 'unshaded'}" onclick="toggleCell(this)" style="width: 40px; height: 40px;">${i + 1}</div>`;
            }
            
            html += `
                        </div>
                    </div>
                </div>
                
                <div class="step-indicator" style="margin-top: 30px;">
                    Step 2: Find GCF of ${num1} and ${den1} = ${g}
                </div>
                
                <div class="step-indicator">
                    Step 3: Group into larger sections (divide by ${g})
                </div>
                
                <div style="text-align: center;">
                    <div class="interactive-grid">
                        <div class="grid-label">Reduced: ${makeFrac(reduced.num, reduced.den)}</div>
                        <div class="area-grid" style="grid-template-columns: repeat(${Math.min(reduced.den, 12)}, 1fr);">
            `;
            
            const cellWidth = Math.floor(400 / reduced.den);
            for (let i = 0; i < reduced.den; i++) {
                const isShaded = i < reduced.num;
                html += `<div class="area-cell ${isShaded ? 'multiply-overlap' : 'unshaded'}" style="width: ${cellWidth}px; height: ${cellWidth}px;">Group ${i + 1}</div>`;
            }
            
            html += `
                        </div>
                    </div>
                </div>
                
                <div class="result-box">
                    ${num1} ÷ ${g} = ${reduced.num}<br>
                    ${den1} ÷ ${g} = ${reduced.den}<br>
                    Result: ${makeFrac(num1, den1)} = ${makeFrac(reduced.num, reduced.den)}
                </div>
                
                <div class="why-box">
                    <h4>💡 What You Discovered:</h4>
                    <p>The shaded area is exactly the same!</p>
                    <p>Reducing doesn't change the value—it just groups pieces into larger sections.</p>
                </div>
            `;
            
            workspace.innerHTML = html;
        }
        
        function toggleCell(cell) {
            if (cell.classList.contains('shaded')) {
                cell.classList.remove('shaded');
                cell.classList.add('unshaded');
            } else if (cell.classList.contains('unshaded')) {
                cell.classList.add('shaded');
                cell.classList.remove('unshaded');
            } else if (cell.classList.contains('multiply-overlap')) {
                cell.classList.remove('multiply-overlap');
                cell.classList.add('unshaded');
            }
        }
        
        // Explore functions (keeping previous code)
        function exploreMultiply() {
            const area = document.getElementById('explore-area');
            area.innerHTML = `
                <h3 style="color: #667eea; margin-bottom: 20px;">WHY Multiplication Works: ${makeFrac(2,3)} × ${makeFrac(3,4)}</h3>
                
                <div class="why-box">
                    <h4>🤔 The Big Question:</h4>
                    <p>Why do we multiply numerators and denominators? Let's see it visually!</p>
                </div>
                
                <div class="visual-model">
