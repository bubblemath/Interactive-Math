
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fractions Explorer</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        
        .streak-display {
            background: rgba(255,255,255,0.2);
            padding: 20px;
            border-radius: 10px;
            margin-top: 15px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .streak-stat {
            text-align: center;
            padding: 10px;
        }
        
        .streak-stat .number {
            font-size: 2.5em;
            font-weight: bold;
            display: block;
        }
        
        .streak-stat .label {
            font-size: 0.9em;
            opacity: 0.9;
        }
        
        .streak-fire {
            font-size: 3em;
            animation: flicker 1.5s infinite;
        }
        
        @keyframes flicker {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        .milestone-badge {
            background: gold;
            color: #333;
            padding: 10px 20px;
            border-radius: 20px;
            font-weight: bold;
            margin-top: 10px;
            display: inline-block;
            animation: bounce 0.5s;
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        .tabs {
            display: flex;
            background: #f5f5f5;
            border-bottom: 3px solid #667eea;
            overflow-x: auto;
        }
        
        .tab {
            flex: 1;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            background: #f5f5f5;
            border: none;
            font-size: 1.1em;
            font-weight: 600;
            color: #555;
            transition: all 0.3s;
            white-space: nowrap;
            min-width: 150px;
        }
        
        .tab:hover {
            background: #e0e0e0;
        }
        
        .tab.active {
            background: white;
            color: #667eea;
            border-bottom: 3px solid #667eea;
            margin-bottom: -3px;
        }
        
        .content {
            padding: 40px;
        }
        
        .tab-content {
            display: none;
        }
        
        .tab-content.active {
            display: block;
            animation: fadeIn 0.5s;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .concept-box {
            background: #f9f9f9;
            border-left: 5px solid #667eea;
            padding: 20px;
            margin: 20px 0;
            border-radius: 5px;
        }
        
        .concept-box h3 {
            color: #667eea;
            margin-bottom: 15px;
        }
        
        /* Beautiful fraction display */
        .frac {
            display: inline-block;
            vertical-align: middle;
            text-align: center;
            margin: 0 5px;
        }
        
        .frac > span {
            display: block;
            padding: 0.1em;
        }
        
        .frac .top {
            border-bottom: 2px solid #333;
            font-size: 1.2em;
        }
        
        .frac .bottom {
            font-size: 1.2em;
        }
        
        .problem {
            background: #f9f9f9;
            padding: 25px;
            margin: 20px 0;
            border-radius: 10px;
            border: 2px solid #e0e0e0;
        }
        
        .problem h4 {
            color: #667eea;
            margin-bottom: 15px;
            font-size: 1.2em;
        }
        
        .problem-text {
            font-size: 1.5em;
            margin: 15px 0;
            color: #333;
            font-weight: 600;
        }
        
        input[type="number"], select {
            padding: 12px;
            font-size: 1.1em;
            border: 2px solid #ddd;
            border-radius: 5px;
            width: 100px;
            margin: 10px 5px;
        }
        
        input[type="number"]:focus, select:focus {
            outline: none;
            border-color: #667eea;
        }
        
        .check-btn, .randomize-btn, .build-btn {
            background: #667eea;
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 1.1em;
            border-radius: 5px;
            cursor: pointer;
            margin: 10px 5px;
            transition: all 0.3s;
        }
        
        .randomize-btn {
            background: #28a745;
        }
        
        .build-btn {
            background: #ff6b6b;
        }
        
        .check-btn:hover {
            background: #764ba2;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        .randomize-btn:hover {
            background: #218838;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        .build-btn:hover {
            background: #ee5a52;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        .feedback {
            margin-top: 15px;
            padding: 15px;
            border-radius: 5px;
            font-weight: 600;
            display: none;
        }
        
        .feedback.correct {
            background: #d4edda;
            color: #155724;
            border: 2px solid #c3e6cb;
            display: block;
        }
        
        .feedback.incorrect {
            background: #fff3cd;
            color: #856404;
            border: 2px solid #ffeaa7;
            display: block;
        }
        
        .button-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 10px;
        }
        
        .rules-table {
            width: 100%;
            margin: 20px 0;
            border-collapse: collapse;
        }
        
        .rules-table th, .rules-table td {
            padding: 15px;
            text-align: left;
            border: 1px solid #ddd;
        }
        
        .rules-table th {
            background: #667eea;
            color: white;
        }
        
        .rules-table tr:nth-child(even) {
            background: #f9f9f9;
        }
        
        .example-box {
            background: white;
            border: 2px solid #667eea;
            border-radius: 10px;
            padding: 20px;
            margin: 15px 0;
        }
        
        .step {
            margin: 10px 0;
            padding: 10px;
            background: #f0f0f0;
            border-radius: 5px;
        }
        
        /* Visual models */
        .visual-model {
            margin: 20px 0;
            padding: 20px;
            background: white;
            border: 2px solid #667eea;
            border-radius: 10px;
        }
        
        .area-model {
            display: inline-block;
            margin: 10px;
        }
        
        .area-grid {
            display: grid;
            gap: 2px;
            border: 3px solid #333;
            width: fit-content;
        }
        
        .area-cell {
            width: 40px;
            height: 40px;
            border: 1px solid #999;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            transition: all 0.3s;
            cursor: pointer;
        }
        
        .area-cell.shaded {
            background: #667eea;
            color: white;
        }
        
        .area-cell.unshaded {
            background: white;
        }
        
        .area-cell.multiply-overlap {
            background: #28a745;
            color: white;
        }
        
        .area-cell:hover {
            opacity: 0.8;
            transform: scale(1.05);
        }
        
        .why-box {
            background: #fff3cd;
            border-left: 5px solid #ffc107;
            padding: 20px;
            margin: 20px 0;
            border-radius: 5px;
        }
        
        .why-box h4 {
            color: #856404;
            margin-bottom: 10px;
        }
        
        /* Build Your Own styles */
        .build-input-section {
            background: #f9f9f9;
            padding: 25px;
            border-radius: 10px;
            margin: 20px 0;
        }
        
        .build-input-group {
            display: flex;
            gap: 15px;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
            margin: 15px 0;
        }
        
        .build-workspace {
            background: white;
            border: 3px solid #667eea;
            border-radius: 10px;
            padding: 30px;
            margin: 20px 0;
            min-height: 400px;
        }
        
        .interactive-grid {
            display: inline-block;
            margin: 20px;
        }
        
        .grid-label {
            text-align: center;
            font-weight: bold;
            font-size: 1.2em;
            margin-bottom: 10px;
            color: #667eea;
        }
        
        .step-indicator {
            background: #667eea;
            color: white;
            padding: 15px;
            border-radius: 10px;
            margin: 20px 0;
            font-size: 1.2em;
            text-align: center;
        }
        
        .result-box {
            background: #28a745;
            color: white;
            padding: 20px;
            border-radius: 10px;
            margin: 20px 0;
            font-size: 1.5em;
            text-align: center;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🔢 Fractions Explorer</h1>
            <p>Master fractions with interactive learning!</p>
            
            <div class="streak-display">
                <div class="streak-stat">
                    <span class="streak-fire">🔥</span>
                    <span class="number" id="current-streak">0</span>
                    <span class="label">Current Streak</span>
                </div>
                <div class="streak-stat">
                    <span class="number" id="total-correct">0</span>
                    <span class="label">✅ Correct</span>
                </div>
                <div class="streak-stat">
                    <span class="number" id="total-incorrect">0</span>
                    <span class="label">❌ Incorrect</span>
                </div>
                <div class="streak-stat">
                    <span class="number" id="success-rate">0%</span>
                    <span class="label">Success Rate</span>
                </div>
            </div>
            <div id="milestone-display"></div>
        </div>
        
        <div class="tabs">
            <button class="tab active" onclick="openTab(event, 'fraction-rules')">Fraction Rules</button>
            <button class="tab" onclick="openTab(event, 'explore-rules')">Explore the Rules</button>
            <button class="tab" onclick="openTab(event, 'build-your-own')">Build Your Own</button>
            <button class="tab" onclick="openTab(event, 'practice')">Practice Problems</button>
        </div>
        
        <div class="content">
            <!-- Fraction Rules Tab -->
            <div id="fraction-rules" class="tab-content active">
                <h2>Understanding Fractions</h2>
                
                <div class="concept-box">
                    <h3>What is a Fraction?</h3>
                    <p>A fraction represents a part of a whole. It has two parts:</p>
                    <ul style="margin-left: 20px; line-height: 1.8;">
                        <li><strong>Numerator</strong> (top number) - tells how many parts you have</li>
                        <li><strong>Denominator</strong> (bottom number) - tells how many equal parts the whole is divided into</li>
                    </ul>
                </div>
                
                <div class="concept-box">
                    <h3>Reducing Fractions</h3>
                    <p><strong>Rule:</strong> Divide both the numerator and denominator by their Greatest Common Factor (GCF)</p>
                    <div class="example-box">
                        <strong>Example: Reduce <span class="frac"><span class="top">12</span><span class="bottom">18</span></span></strong>
                        <div class="step">Step 1: Find the GCF of 12 and 18 → GCF = 6</div>
                        <div class="step">Step 2: Divide both by 6 → 12÷6 = 2, 18÷6 = 3</div>
                        <div class="step">Answer: <span class="frac"><span class="top">12</span><span class="bottom">18</span></span> = <span class="frac"><span class="top">2</span><span class="bottom">3</span></span></div>
                    </div>
                </div>
                
                <div class="concept-box">
                    <h3>Multiplying Fractions</h3>
                    <p><strong>Rule:</strong> Multiply numerators together, multiply denominators together</p>
                    <p style="font-size: 1.3em; margin: 10px 0;">
                        <span class="frac"><span class="top">a</span><span class="bottom">b</span></span> × 
                        <span class="frac"><span class="top">c</span><span class="bottom">d</span></span> = 
                        <span class="frac"><span class="top">a×c</span><span class="bottom">b×d</span></span>
                    </p>
                    <div class="example-box">
                        <strong>Example: <span class="frac"><span class="top">2</span><span class="bottom">3</span></span> × <span class="frac"><span class="top">4</span><span class="bottom">5</span></span></strong>
                        <div class="step">Multiply numerators: 2 × 4 = 8</div>
                        <div class="step">Multiply denominators: 3 × 5 = 15</div>
                        <div class="step">Answer: <span class="frac"><span class="top">8</span><span class="bottom">15</span></span></div>
                    </div>
                </div>
                
                <div class="concept-box">
                    <h3>Dividing Fractions</h3>
                    <p><strong>Rule:</strong> "Multiply by the reciprocal" or "Keep, Change, Flip"</p>
                    <ul style="margin-left: 20px; line-height: 1.8;">
                        <li><strong>Keep</strong> the first fraction the same</li>
                        <li><strong>Change</strong> division to multiplication</li>
                        <li><strong>Flip</strong> the second fraction (reciprocal)</li>
                    </ul>
                    <div class="example-box">
                        <strong>Example: <span class="frac"><span class="top">2</span><span class="bottom">3</span></span> ÷ <span class="frac"><span class="top">4</span><span class="bottom">5</span></span></strong>
                        <div class="step">Keep: <span class="frac"><span class="top">2</span><span class="bottom">3</span></span></div>
                        <div class="step">Change: ÷ becomes ×</div>
                        <div class="step">Flip: <span class="frac"><span class="top">4</span><span class="bottom">5</span></span> becomes <span class="frac"><span class="top">5</span><span class="bottom">4</span></span></div>
                        <div class="step">Multiply: <span class="frac"><span class="top">2</span><span class="bottom">3</span></span> × <span class="frac"><span class="top">5</span><span class="bottom">4</span></span> = <span class="frac"><span class="top">10</span><span class="bottom">12</span></span> = <span class="frac"><span class="top">5</span><span class="bottom">6</span></span></div>
                    </div>
                </div>
                
                <div class="concept-box">
                    <h3>Adding & Subtracting Fractions (Same Denominator)</h3>
                    <p><strong>Rule:</strong> Add or subtract the numerators, keep the denominator the same</p>
                    <div class="example-box">
                        <strong>Example: <span class="frac"><span class="top">3</span><span class="bottom">8</span></span> + <span class="frac"><span class="top">2</span><span class="bottom">8</span></span> = <span class="frac"><span class="top">5</span><span class="bottom">8</span></span></strong>
                        <div class="step">Same denominator (8), so add numerators: 3 + 2 = 5</div>
                        <div class="step">Keep denominator: 8</div>
                    </div>
                </div>
                
                <div class="concept-box">
                    <h3>Adding & Subtracting Fractions (Different Denominators)</h3>
                    <p><strong>Steps:</strong></p>
                    <ol style="margin-left: 20px; line-height: 1.8;">
                        <li>Find the Least Common Denominator (LCD)</li>
                        <li>Convert each fraction to an equivalent fraction with the LCD</li>
                        <li>Add or subtract the numerators, keep the denominator</li>
                    </ol>
                    <div class="example-box">
                        <strong>Example: <span class="frac"><span class="top">1</span><span class="bottom">4</span></span> + <span class="frac"><span class="top">1</span><span class="bottom">6</span></span></strong>
                        <div class="step">Step 1: LCD of 4 and 6 = 12</div>
                        <div class="step">Step 2: <span class="frac"><span class="top">1</span><span class="bottom">4</span></span> = <span class="frac"><span class="top">3</span><span class="bottom">12</span></span> and <span class="frac"><span class="top">1</span><span class="bottom">6</span></span> = <span class="frac"><span class="top">2</span><span class="bottom">12</span></span></div>
                        <div class="step">Step 3: <span class="frac"><span class="top">3</span><span class="bottom">12</span></span> + <span class="frac"><span class="top">2</span><span class="bottom">12</span></span> = <span class="frac"><span class="top">5</span><span class="bottom">12</span></span></div>
                    </div>
                </div>
            </div>
            
            <!-- Explore Rules Tab -->
            <div id="explore-rules" class="tab-content">
                <h2>🔍 Explore WHY Fraction Rules Work</h2>
                
                <div class="concept-box">
                    <h3>Visual Models to Understand Fractions</h3>
                    <p>Click each button to see visual proof of why the rules work!</p>
                </div>
                
                <div style="margin: 20px 0;">
                    <button class="check-btn" onclick="exploreMultiply()">Why Multiplication Works</button>
                    <button class="check-btn" onclick="exploreDivide()">Why Division Works</button>
                    <button class="check-btn" onclick="exploreAdd()">Why Addition Works</button>
                    <button class="check-btn" onclick="exploreReduce()">Why Reducing Works</button>
                </div>
                
                <div id="explore-area" style="min-height: 400px; background: white; border: 3px solid #667eea; border-radius: 10px; padding: 30px; margin: 20px 0;">
                    <p style="text-align: center; color: #999; font-size: 1.2em;">Click a button above to explore fraction operations visually!</p>
                </div>
            </div>
            
            <!-- Build Your Own Tab -->
            <div id="build-your-own" class="tab-content">
                <h2>🎨 Build Your Own Fraction Operation</h2>
                
                <div class="concept-box">
                    <h3>Create and Visualize Your Own Fraction Problems!</h3>
                    <p>Enter two fractions and choose an operation. Then build the visual model step-by-step to see how it works!</p>
                </div>
                
                <div class="build-input-section">
                    <div class="build-input-group">
                        <label style="font-weight: bold;">First Fraction:</label>
                        <input type="number" id="build-num1" value="2" min="1" max="12">
                        <span style="font-size: 1.5em;">/</span>
                        <input type="number" id="build-den1" value="3" min="1" max="12">
                        
                        <select id="build-operation" style="width: 150px;">
                            <option value="multiply">× Multiply</option>
                            <option value="divide">÷ Divide</option>
                            <option value="add">+ Add</option>
                            <option value="subtract">− Subtract</option>
                            <option value="reduce">Reduce</option>
                        </select>
                        
                        <label style="font-weight: bold;">Second Fraction:</label>
                        <input type="number" id="build-num2" value="3" min="1" max="12">
                        <span style="font-size: 1.5em;">/</span>
                        <input type="number" id="build-den2" value="4" min="1" max="12">
                        
                        <button class="build-btn" onclick="buildFractionModel()">🎨 Build Model</button>
                    </div>
                </div>
                
                <div id="build-workspace" class="build-workspace">
                    <p style="text-align: center; color: #999; font-size: 1.2em;">Enter your fractions and click "Build Model" to start!</p>
                </div>
            </div>
            
            <!-- Practice Problems Tab -->
            <div id="practice" class="tab-content">
                <h2>Practice Problems</h2>
                
                <!-- Problem 1: Reducing Fractions -->
                <div class="problem">
                    <h4>Problem 1: Reducing Fractions</h4>
                    <p>Reduce the fraction to its simplest form:</p>
                    <p class="problem-text">
                        <span class="frac"><span class="top" id="p1-num">12</span><span class="bottom" id="p1-den">18</span></span> = 
                        <input type="number" id="p1-answer-num" placeholder="numerator" style="width: 120px;"> / 
                        <input type="number" id="p1-answer-den" placeholder="denominator" style="width: 120px;">
                    </p>
                    <div class="button-group">
                        <button class="check-btn" onclick="checkProblem1()">Check Answer</button>
                        <button class="randomize-btn" onclick="randomizeProblem1()">🎲 New Problem</button>
                    </div>
                    <div id="feedback1" class="feedback"></div>
                </div>
                
                <!-- Problem 2: Multiplying Fractions -->
                <div class="problem">
                    <h4>Problem 2: Multiplying Fractions</h4>
                    <p class="problem-text">
                        <span class="frac"><span class="top" id="p2-num1">2</span><span class="bottom" id="p2-den1">3</span></span> × 
                        <span class="frac"><span class="top" id="p2-num2">4</span><span class="bottom" id="p2-den2">5</span></span> = 
                        <input type="number" id="p2-answer-num" placeholder="numerator" style="width: 120px;"> / 
                        <input type="number" id="p2-answer-den" placeholder="denominator" style="width: 120px;">
                    </p>
                    <div class="button-group">
                        <button class="check-btn" onclick="checkProblem2()">Check Answer</button>
                        <button class="randomize-btn" onclick="randomizeProblem2()">🎲 New Problem</button>
                    </div>
                    <div id="feedback2" class="feedback"></div>
                </div>
                
                <!-- Problem 3: Dividing Fractions -->
                <div class="problem">
                    <h4>Problem 3: Dividing Fractions</h4>
                    <p class="problem-text">
                        <span class="frac"><span class="top" id="p3-num1">3</span><span class="bottom" id="p3-den1">4</span></span> ÷ 
                        <span class="frac"><span class="top" id="p3-num2">2</span><span class="bottom" id="p3-den2">5</span></span> = 
                        <input type="number" id="p3-answer-num" placeholder="numerator" style="width: 120px;"> / 
                        <input type="number" id="p3-answer-den" placeholder="denominator" style="width: 120px;">
                    </p>
                    <div class="button-group">
                        <button class="check-btn" onclick="checkProblem3()">Check Answer</button>
                        <button class="randomize-btn" onclick="randomizeProblem3()">🎲 New Problem</button>
                    </div>
                    <div id="feedback3" class="feedback"></div>
                </div>
                
                <!-- Problem 4: Adding Fractions (Same Denominator) -->
                <div class="problem">
                    <h4>Problem 4: Adding Fractions with Same Denominator</h4>
                    <p class="problem-text">
                        <span class="frac"><span class="top" id="p4-num1">3</span><span class="bottom" id="p4-den">8</span></span> + 
                        <span class="frac"><span class="top" id="p4-num2">2</span><span class="bottom" id="p4-den2">8</span></span> = 
                        <input type="number" id="p4-answer-num" placeholder="numerator" style="width: 120px;"> / 
                        <input type="number" id="p4-answer-den" placeholder="denominator" style="width: 120px;">
                    </p>
                    <div class="button-group">
                        <button class="check-btn" onclick="checkProblem4()">Check Answer</button>
                        <button class="randomize-btn" onclick="randomizeProblem4()">🎲 New Problem</button>
                    </div>
                    <div id="feedback4" class="feedback"></div>
                </div>
                
                <!-- Problem 5: Subtracting Fractions (Same Denominator) -->
                <div class="problem">
                    <h4>Problem 5: Subtracting Fractions with Same Denominator</h4>
                    <p class="problem-text">
                        <span class="frac"><span class="top" id="p5-num1">7</span><span class="bottom" id="p5-den">10</span></span> - 
