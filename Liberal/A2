            let message = '';
            
            if (currentStreak === 3) {
                message = '🌟 3 in a row! You\'re on fire!';
            } else if (currentStreak === 5) {
                message = '🎯 5 streak! Excellent work!';
            } else if (currentStreak === 7) {
                message = '🏆 Lucky 7! You\'re a fraction master!';
            } else if (currentStreak === 10) {
                message = '💎 10 STREAK! Absolutely incredible!';
            } else if (currentStreak === 15) {
                message = '👑 15 STREAK! You\'re unstoppable!';
            } else if (currentStreak === 20) {
