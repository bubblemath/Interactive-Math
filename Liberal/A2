    <script>
        // Streak tracking
        let currentStreak = 0;
        let totalCorrect = 0;
        let totalIncorrect = 0;
        
        // Problem states
        let problemStates = {
            p1: { num: 12, den: 18 },
            p2: { num1: 2, den1: 3, num2: 4, den2: 5 },
            p3: { num1: 3, den1: 4, num2: 2, den2: 5 },
            p4: { num1: 3, num2: 2, den: 8 },
            p5: { num1: 7, num2: 3, den: 10 },
            p6: { num1: 1, den1: 4, num2: 1, den2: 6 }
        };
        
        function openTab(evt, tabName) {
