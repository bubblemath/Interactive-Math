                        borderColor: '#4f4',
                        borderWidth: 3,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            type: 'linear',
                            title: {
                                display: true,
                                text: 'z-value',
                                font: {size: 14}
                            }
                        },
                        y: {
                            title: {
                                display: true,
                                text: 'Probability Density',
                                font: {size: 14}
                            }
                        }
                    },
                    plugins: {
                        title: {
                            display: true,
                            text: 'Normal Model for Proportion (p₀ = ' + formatNumber(p0) + ', p̂ = ' + formatNumber(phat) + ')',
                            font: {size: 16}
