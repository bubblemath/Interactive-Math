        function loadPracticeQuestions() {
            if (practiceFilter === 'all') {
                practiceQuestions = [...questionBank].sort(() => Math.random() - 0.5);
            } else {
                practiceQuestions = questionBank.filter(q => q.lesson === practiceFilter).sort(() => Math.random() - 0.5);
            }
        }

        function displayPracticeQuestion() {
            if (practiceIndex >= practiceQuestions.length) {
                showPracticeResults();
                return;
            }

            practiceAnswered = false;
            const q = practiceQuestions[practiceIndex];
            
            document.getElementById('practiceQNum').textContent = `Question ${practiceIndex + 1} of ${practiceQuestions.length}`;
            document.getElementById('practiceQLesson').textContent = q.lesson === 'l1' ? 'Lesson 1' : q.lesson === 'l2' ? 'Lesson 2' : 'Lesson 3';
            document.getElementById('practiceQLesson').className = `question-lesson ${q.lesson}`;
            document.getElementById('practiceQText').textContent = q.question;

            const optionsContainer = document.getElementById('practiceOptions');
            optionsContainer.innerHTML = '';
            q.options.forEach((opt, i) => {
                const btn = document.createElement('button');
                btn.className = 'answer-btn';
                btn.textContent = opt;
                btn.onclick = () => checkPracticeAnswer(i);
                optionsContainer.appendChild(btn);
            });

            document.getElementById('practiceFeedback').style.display = 'none';
            document.getElementById('practiceNextBtn').disabled = true;
        }

        function checkPracticeAnswer(selected) {
            if (practiceAnswered) return;
            practiceAnswered = true;

            const q = practiceQuestions[practiceIndex];
            const buttons = document.querySelectorAll('#practiceOptions .answer-btn');
            buttons.forEach(btn => btn.classList.add('disabled'));

            lessonPerformance[q.lesson].total++;

            const feedbackEl = document.getElementById('practiceFeedback');
            if (selected === q.correct) {
                buttons[selected].classList.add('correct');
                practiceCorrect++;
                practiceStreak++;
                lessonPerformance[q.lesson].correct++;
                feedbackEl.className = 'feedback correct';
                document.getElementById('practiceFeedbackTitle').innerHTML = '✅ Correct!';
                if (practiceStreak >= 3) createConfetti();
            } else {
                buttons[selected].classList.add('wrong');
                buttons[q.correct].classList.add('correct');
                practiceWrong++;
                practiceStreak = 0;
                feedbackEl.className = 'feedback wrong';
                document.getElementById('practiceFeedbackTitle').innerHTML = '❌ Not quite!';
            }

            document.getElementById('practiceFeedbackText').textContent = q.explanation;
            feedbackEl.style.display = 'block';
            updatePracticeStats();
            document.getElementById('practiceNextBtn').disabled = false;
        }

        function skipPracticeQuestion() {
            if (practiceAnswered) return;
            practiceSkipped++;
            updatePracticeStats();
            practiceIndex++;
            displayPracticeQuestion();
        }

        function nextPracticeQuestion() {
            practiceIndex++;
            displayPracticeQuestion();
        }

        function updatePracticeStats() {
            document.getElementById('practiceCorrect').textContent = practiceCorrect;
            document.getElementById('practiceWrong').textContent = practiceWrong;
            document.getElementById('practiceSkipped').textContent = practiceSkipped;
            document.getElementById('practiceStreak').textContent = practiceStreak;
            updateStreakBadge('practiceStreakBadge', practiceStreak);
        }

        function updateStreakBadge(elementId, streak) {
            const badge = document.getElementById(elementId);
            if (streak >= 15) badge.innerHTML = '<span class="streak-badge diamond">💎</span>';
            else if (streak >= 10) badge.innerHTML = '<span class="streak-badge gold">🥇</span>';
            else if (streak >= 5) badge.innerHTML = '<span class="streak-badge silver">🥈</span>';
            else if (streak >= 3) badge.innerHTML = '<span class="streak-badge bronze">🥉</span>';
            else badge.innerHTML = '';
        }

        function showPracticeResults() {
            if (practiceTimerInterval) clearInterval(practiceTimerInterval);
            document.getElementById('practiceQuestionArea').style.display = 'none';
            document.getElementById('practiceResults').style.display = 'block';

            const total = practiceCorrect + practiceWrong + practiceSkipped;
            const percent = total > 0 ? Math.round((practiceCorrect / total) * 100) : 0;

            document.getElementById('practiceResultsPercent').textContent = percent + '%';
            document.getElementById('practiceResultsCircle').style.setProperty('--percent', percent + '%');
            document.getElementById('practiceFinalCorrect').textContent = practiceCorrect;
            document.getElementById('practiceFinalWrong').textContent = practiceWrong;
            document.getElementById('practiceFinalSkipped').textContent = practiceSkipped;

            const diagList = document.getElementById('practiceDiagnosticList');
            diagList.innerHTML = '';
            
            if (percent >= 90) {
                diagList.innerHTML = '<li>Excellent! You\'re well-prepared for the exam.</li>';
            } else if (percent >= 70) {
                diagList.innerHTML = '<li>Good progress! Review the topics below for improvement.</li>';
            } else {
                diagList.innerHTML = '<li>Keep practicing! Focus on the areas identified below.</li>';
            }

            for (const [lesson, perf] of Object.entries(lessonPerformance)) {
                if (perf.total > 0) {
                    const lessonPercent = Math.round((perf.correct / perf.total) * 100);
                    if (lessonPercent < 70) {
                        const names = { l1: 'Lesson 1: Probability', l2: 'Lesson 2: Counting', l3: 'Lesson 3: Data' };
                        const li = document.createElement('li');
                        li.textContent = `Review ${names[lesson]} (${lessonPercent}% correct)`;
                        diagList.appendChild(li);
                    }
                }
            }
        }

        function resetPractice() {
            practiceIndex = 0;
            practiceCorrect = 0;
            practiceWrong = 0;
            practiceSkipped = 0;
            practiceStreak = 0;
            practiceAnswered = false;
            practiceTimerSeconds = 0;
            lessonPerformance = { l1: { correct: 0, total: 0 }, l2: { correct: 0, total: 0 }, l3: { correct: 0, total: 0 } };
            
            updatePracticeStats();
            document.getElementById('practiceTimerDisplay').textContent = '0:00';
            loadPracticeQuestions();
            displayPracticeQuestion();
        }

        function restartPractice() {
            document.getElementById('practiceQuestionArea').style.display = 'block';
            document.getElementById('practiceResults').style.display = 'none';
            resetPractice();
            if (document.getElementById('practiceTimer').checked) startPracticeTimer();
        }

        function togglePracticeTimer() {
            if (document.getElementById('practiceTimer').checked) {
                startPracticeTimer();
            } else {
                if (practiceTimerInterval) clearInterval(practiceTimerInterval);
            }
        }

        function startPracticeTimer() {
            practiceTimerInterval = setInterval(() => {
                practiceTimerSeconds++;
                const mins = Math.floor(practiceTimerSeconds / 60);
                const secs = practiceTimerSeconds % 60;
                document.getElementById('practiceTimerDisplay').textContent = `${mins}:${secs.toString().padStart(2, '0')}`;
            }, 1000);
        }

        // ==================== HOT STREAK ====================
        let hsQuestions = [];
        let hsIndex = 0;
        let hsCorrect = 0;
        let hsWrong = 0;
        let hsStreak = 0;
        let hsBestStreak = 0;
        let hsAnswered = false;

        function startHotStreak() {
            document.getElementById('hotStreakIntro').style.display = 'none';
            document.getElementById('hotStreakGame').style.display = 'block';
            document.getElementById('hotStreakResults').style.display = 'none';
            
            hsQuestions = [...questionBank].sort(() => Math.random() - 0.5);
            hsIndex = 0;
            hsCorrect = 0;
            hsWrong = 0;
            hsStreak = 0;
            hsBestStreak = 0;
            
            updateHsStats();
            displayHsQuestion();
        }

        function displayHsQuestion() {
            hsAnswered = false;
            const q = hsQuestions[hsIndex % hsQuestions.length];
            
            document.getElementById('hsQNum').textContent = `Question ${hsIndex + 1}`;
            document.getElementById('hsQLesson').textContent = q.lesson === 'l1' ? 'Lesson 1' : q.lesson === 'l2' ? 'Lesson 2' : 'Lesson 3';
            document.getElementById('hsQLesson').className = `question-lesson ${q.lesson}`;
            document.getElementById('hsQText').textContent = q.question;

            const optionsContainer = document.getElementById('hsOptions');
            optionsContainer.innerHTML = '';
            q.options.forEach((opt, i) => {
                const btn = document.createElement('button');
                btn.className = 'answer-btn';
                btn.textContent = opt;
                btn.onclick = () => checkHsAnswer(i);
                optionsContainer.appendChild(btn);
            });

            document.getElementById('hsFeedback').style.display = 'none';
            document.getElementById('hsNextBtn').disabled = true;
        }

        function checkHsAnswer(selected) {
            if (hsAnswered) return;
            hsAnswered = true;

            const q = hsQuestions[hsIndex % hsQuestions.length];
            const buttons = document.querySelectorAll('#hsOptions .answer-btn');
            buttons.forEach(btn => btn.classList.add('disabled'));

            const feedbackEl = document.getElementById('hsFeedback');
            if (selected === q.correct) {
                buttons[selected].classList.add('correct');
                hsCorrect++;
                hsStreak++;
                if (hsStreak > hsBestStreak) hsBestStreak = hsStreak;
                feedbackEl.className = 'feedback correct';
                document.getElementById('hsFeedbackTitle').innerHTML = '🔥 Correct! Streak continues!';
                createConfetti();
            } else {
                buttons[selected].classList.add('wrong');
                buttons[q.correct].classList.add('correct');
                hsWrong++;
                hsStreak = 0;
                feedbackEl.className = 'feedback wrong';
                document.getElementById('hsFeedbackTitle').innerHTML = '❌ Streak broken!';
            }

            document.getElementById('hsFeedbackText').textContent = q.explanation;
            feedbackEl.style.display = 'block';
            updateHsStats();
            document.getElementById('hsNextBtn').disabled = false;
        }

        function nextHsQuestion() {
            hsIndex++;
            displayHsQuestion();
        }

        function updateHsStats() {
            document.getElementById('hsCorrect').textContent = hsCorrect;
            document.getElementById('hsWrong').textContent = hsWrong;
            document.getElementById('hsStreak').textContent = hsStreak;
            document.getElementById('hsBestStreak').textContent = hsBestStreak;
            updateStreakBadge('hsStreakBadge', hsStreak);
        }

        function endHotStreak() {
            document.getElementById('hotStreakGame').style.display = 'none';
            document.getElementById('hotStreakResults').style.display = 'block';

            const total = hsCorrect + hsWrong;
            const percent = total > 0 ? Math.round((hsCorrect / total) * 100) : 0;

            document.getElementById('hsResultsPercent').textContent = percent + '%';
            document.getElementById('hsResultsCircle').style.setProperty('--percent', percent + '%');
            document.getElementById('hsFinalCorrect').textContent = hsCorrect;
            document.getElementById('hsFinalWrong').textContent = hsWrong;
            document.getElementById('hsFinalBest').textContent = hsBestStreak;
        }

        function restartHotStreak() {
            startHotStreak();
        }

        // ==================== UTILITIES ====================
        function openCalculator() {
            document.getElementById('desmosModal').classList.add('active');
        }

        function closeCalculator() {
            document.getElementById('desmosModal').classList.remove('active');
        }

        function copyPrompt(btn) {
            const promptText = btn.previousElementSibling.textContent;
            navigator.clipboard.writeText(promptText).then(() => {
                btn.textContent = '✓ Copied!';
                setTimeout(() => btn.textContent = '📋 Copy Prompt', 2000);
            });
        }

        function createConfetti() {
            const container = document.getElementById('confetti');
            const colors = ['#667eea', '#764ba2', '#f093fb', '#38ef7d', '#ffd93d'];
            
            for (let i = 0; i < 40; i++) {
                const piece = document.createElement('div');
                piece.className = 'confetti-piece';
                piece.style.left = Math.random() * 100 + '%';
                piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                piece.style.animationDelay = Math.random() * 0.5 + 's';
                container.appendChild(piece);
                setTimeout(() => piece.remove(), 3000);
            }
        }

        // ==================== INITIALIZATION ====================
        window.onload = function() {
            updateFlashcard();
            loadPracticeQuestions();
            displayPracticeQuestion();
            if (typeof MathJax !== 'undefined') MathJax.typesetPromise();
        };
    </script>
</body>
</html>
