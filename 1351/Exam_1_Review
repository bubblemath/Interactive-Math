                <h2>📐 Key Formulas</h2>
                <div class="formula-grid">
                    <div class="formula-card purple">
                        <h4>Probability</h4>
                        <div class="formula">\(P(E) = \frac{n(E)}{n(S)}\)</div>
                        <div class="description">Favorable ÷ Total outcomes</div>
                    </div>
                    <div class="formula-card blue">
                        <h4>Complement</h4>
                        <div class="formula">\(P(E') = 1 - P(E)\)</div>
                        <div class="description">Probability of NOT E</div>
                    </div>
                    <div class="formula-card green">
                        <h4>Permutations</h4>
                        <div class="formula">\(P(n,r) = \frac{n!}{(n-r)!}\)</div>
                        <div class="description">Order MATTERS</div>
                    </div>
                    <div class="formula-card teal">
                        <h4>Combinations</h4>
                        <div class="formula">\(C(n,r) = \frac{n!}{r!(n-r)!}\)</div>
                        <div class="description">Order DOESN'T matter</div>
                    </div>
                    <div class="formula-card pink">
                        <h4>Expected Value</h4>
                        <div class="formula">\(E(X) = \sum x \cdot P(x)\)</div>
                        <div class="description">Average outcome</div>
                    </div>
                    <div class="formula-card orange">
                        <h4>Pie Chart Degrees</h4>
                        <div class="formula">\(\frac{\text{Part}}{\text{Whole}} \times 360°\)</div>
                        <div class="description">Sectors sum to 360°</div>
                    </div>
                </div>
            </div>

