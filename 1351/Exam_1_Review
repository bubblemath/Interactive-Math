
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Math 1351 - Exam 1 Review: Lessons 1-3</title>
    <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            color: #e0e0e0;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
            color: white;
            padding: 35px 30px;
            text-align: center;
            border-radius: 20px;
            margin-bottom: 25px;
            box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
            position: relative;
        }

        .header h1 {
            font-size: 2.2em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .header p {
            font-size: 1.1em;
            opacity: 0.95;
        }

        .header .exam-badge {
            position: absolute;
            top: 20px;
            right: 25px;
            background: rgba(255,255,255,0.2);
            padding: 8px 18px;
            border-radius: 25px;
            font-weight: bold;
        }

        /* Tab Navigation */
        .tab-nav {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 20px;
            justify-content: center;
        }

        .tab-btn {
            padding: 12px 20px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 0.95em;
            font-weight: 600;
            transition: all 0.3s;
            background: rgba(40, 40, 60, 0.8);
            color: #a0a0a0;
            border: 2px solid transparent;
        }

        .tab-btn:hover {
            background: rgba(60, 60, 80, 0.9);
            color: #fff;
        }

        .tab-btn.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Cards */
        .card {
            background: rgba(30, 30, 50, 0.95);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 20px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .card h2 {
            color: #667eea;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card h3 {
            color: #764ba2;
            margin: 20px 0 15px 0;
            font-size: 1.1em;
        }

        /* Lesson Overview Cards */
        .lesson-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .lesson-card {
            background: rgba(40, 40, 60, 0.7);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
            transition: transform 0.3s;
        }

        .lesson-card:hover {
            transform: translateY(-5px);
        }

        .lesson-card-header {
            padding: 20px;
            color: white;
        }

        .lesson-card:nth-child(1) .lesson-card-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .lesson-card:nth-child(2) .lesson-card-header { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
        .lesson-card:nth-child(3) .lesson-card-header { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }

        .lesson-card-header h3 {
            color: white;
            margin: 0;
            font-size: 1.2em;
        }

        .lesson-card-body {
            padding: 20px;
        }

        .lesson-card-body ul {
            list-style: none;
            padding: 0;
        }

        .lesson-card-body li {
            padding: 8px 0;
            padding-left: 20px;
            position: relative;
            color: #ccc;
            font-size: 0.95em;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .lesson-card-body li::before {
            content: '•';
            position: absolute;
            left: 0;
            color: #667eea;
        }

        .lesson-link {
            display: block;
            margin-top: 15px;
            padding: 10px 15px;
            background: rgba(102, 126, 234, 0.2);
            border: 1px solid #667eea;
            border-radius: 8px;
            color: #667eea;
            text-decoration: none;
            text-align: center;
            transition: all 0.3s;
        }

        .lesson-link:hover {
            background: rgba(102, 126, 234, 0.4);
            color: white;
        }

        /* Formula Cards */
        .formula-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .formula-card {
            background: rgba(40, 40, 60, 0.7);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            border-top: 4px solid;
            transition: transform 0.3s;
        }

        .formula-card:hover {
            transform: translateY(-3px);
        }

        .formula-card.purple { border-top-color: #764ba2; }
        .formula-card.blue { border-top-color: #667eea; }
        .formula-card.green { border-top-color: #38ef7d; }
        .formula-card.pink { border-top-color: #f093fb; }
        .formula-card.teal { border-top-color: #11998e; }
        .formula-card.orange { border-top-color: #ffa726; }

        .formula-card h4 {
            color: #fff;
            margin-bottom: 12px;
            font-size: 0.95em;
        }

        .formula-card .formula {
            font-size: 1.2em;
            color: #667eea;
            margin-bottom: 8px;
        }

        .formula-card .description {
            color: #999;
            font-size: 0.85em;
        }

        /* Flashcard Styles */
        .flashcard-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        .flashcard {
            width: 100%;
            max-width: 500px;
            height: 280px;
            perspective: 1000px;
            cursor: pointer;
        }

        .flashcard-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }

        .flashcard.flipped .flashcard-inner {
            transform: rotateY(180deg);
        }

        .flashcard-front, .flashcard-back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 15px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 25px;
            text-align: center;
        }

        .flashcard-front {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .flashcard-back {
            background: rgba(40, 40, 60, 0.95);
            border: 2px solid #667eea;
            transform: rotateY(180deg);
        }

        .flashcard-term {
            font-size: 1.4em;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .flashcard-lesson {
            font-size: 0.85em;
            opacity: 0.8;
            margin-bottom: 15px;
        }

        .flashcard-hint {
            font-size: 0.9em;
            opacity: 0.7;
        }

        .flashcard-definition {
            font-size: 1.1em;
            color: #ccc;
            line-height: 1.6;
        }

        .flashcard-formula {
            font-size: 1.3em;
            color: #667eea;
            margin-top: 15px;
        }

        .flashcard-nav {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .flashcard-btn {
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 600;
            transition: all 0.3s;
        }

        .flashcard-btn.prev, .flashcard-btn.next {
            background: rgba(102, 126, 234, 0.2);
            border: 2px solid #667eea;
            color: #667eea;
        }

        .flashcard-btn.prev:hover, .flashcard-btn.next:hover {
            background: rgba(102, 126, 234, 0.4);
            color: white;
        }

        .flashcard-counter {
            color: #ccc;
            font-size: 1em;
        }

        .flashcard-mastery {
            display: flex;
            gap: 15px;
            margin-top: 15px;
        }

        .mastery-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.95em;
            transition: all 0.3s;
        }

        .mastery-btn.mastered {
            background: rgba(56, 239, 125, 0.2);
            border: 2px solid #38ef7d;
            color: #38ef7d;
        }

        .mastery-btn.needs-practice {
            background: rgba(245, 87, 108, 0.2);
            border: 2px solid #f5576c;
            color: #f5576c;
        }

        .mastery-btn:hover {
            transform: scale(1.05);
        }

        .mastery-stats {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 20px;
            padding: 15px;
            background: rgba(40, 40, 60, 0.7);
            border-radius: 10px;
        }

        .mastery-stat {
            text-align: center;
        }

        .mastery-stat .num {
            font-size: 1.5em;
            font-weight: bold;
        }

        .mastery-stat .label {
            font-size: 0.85em;
            color: #999;
        }

        .mastery-stat.mastered .num { color: #38ef7d; }
        .mastery-stat.needs .num { color: #f5576c; }

        /* Practice Zone Styles */
        .practice-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
        }

        .timer-section {
            display: flex;
            align-items: center;
            gap: 15px;
            background: rgba(40, 40, 60, 0.7);
            padding: 12px 18px;
            border-radius: 10px;
        }

        .toggle-switch {
            position: relative;
            width: 50px;
            height: 26px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(60, 60, 80, 0.8);
            border-radius: 26px;
            transition: 0.3s;
        }

        .toggle-slider::before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background: white;
            border-radius: 50%;
            transition: 0.3s;
        }

        .toggle-switch input:checked + .toggle-slider {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .toggle-switch input:checked + .toggle-slider::before {
            transform: translateX(24px);
        }

        .timer-display {
            font-size: 1.6em;
            font-weight: bold;
            color: #667eea;
            font-family: 'Courier New', monospace;
            min-width: 70px;
        }

        /* Stats Bar */
        .stats-bar {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 20px;
        }

        .stat-item {
            text-align: center;
            padding: 12px 20px;
            background: rgba(40, 40, 60, 0.7);
            border-radius: 10px;
            min-width: 90px;
        }

        .stat-item .label {
            font-size: 0.8em;
            color: #999;
            margin-bottom: 4px;
        }

        .stat-item .value {
            font-size: 1.4em;
            font-weight: bold;
        }

        .stat-item.correct .value { color: #38ef7d; }
        .stat-item.wrong .value { color: #f5576c; }
        .stat-item.skipped .value { color: #ffd93d; }
        .stat-item.streak .value { color: #667eea; }

        .streak-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 15px;
            font-size: 0.8em;
            margin-left: 8px;
        }

        .streak-badge.bronze { background: #cd7f32; color: white; }
        .streak-badge.silver { background: #c0c0c0; color: #333; }
        .streak-badge.gold { background: #ffd700; color: #333; }
        .streak-badge.diamond { background: linear-gradient(135deg, #b9f2ff, #89cff0); color: #333; }

        /* Category Filter */
        .category-filter {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 20px;
        }

        .filter-btn {
            padding: 10px 18px;
            border: 2px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            background: rgba(40, 40, 60, 0.7);
            color: #ccc;
            cursor: pointer;
            font-size: 0.9em;
            transition: all 0.3s;
        }

        .filter-btn:hover {
            border-color: #667eea;
            color: #fff;
        }

        .filter-btn.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-color: transparent;
        }

        /* Question Card */
        .question-card {
            background: rgba(40, 40, 60, 0.7);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 20px;
        }

        .question-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .question-number {
            color: #667eea;
            font-size: 0.9em;
        }

        .question-lesson {
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 0.8em;
        }

        .question-lesson.l1 { background: rgba(102, 126, 234, 0.2); color: #667eea; }
        .question-lesson.l2 { background: rgba(56, 239, 125, 0.2); color: #38ef7d; }
        .question-lesson.l3 { background: rgba(240, 147, 251, 0.2); color: #f093fb; }

        .question-text {
            font-size: 1.15em;
            color: #fff;
            line-height: 1.6;
            margin-bottom: 20px;
        }

        .answer-options {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .answer-btn {
            padding: 14px 18px;
            border: 2px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            background: rgba(30, 30, 50, 0.8);
            color: #ccc;
            cursor: pointer;
            font-size: 1em;
            text-align: left;
            transition: all 0.3s;
        }

        .answer-btn:hover:not(.disabled) {
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.1);
            color: #fff;
        }

        .answer-btn.correct {
            border-color: #38ef7d;
            background: rgba(56, 239, 125, 0.2);
            color: #38ef7d;
        }

        .answer-btn.wrong {
            border-color: #f5576c;
            background: rgba(245, 87, 108, 0.2);
            color: #f5576c;
        }

        .answer-btn.disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

        .feedback {
            padding: 18px;
            border-radius: 10px;
            margin-top: 18px;
            display: none;
        }

        .feedback.correct {
            background: rgba(56, 239, 125, 0.15);
            border: 1px solid #38ef7d;
        }

        .feedback.wrong {
            background: rgba(245, 87, 108, 0.15);
            border: 1px solid #f5576c;
        }

        .feedback h4 {
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .feedback.correct h4 { color: #38ef7d; }
        .feedback.wrong h4 { color: #f5576c; }

        .feedback p {
            color: #ccc;
            line-height: 1.5;
        }

        .nav-buttons {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin-top: 18px;
        }

        .nav-btn {
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .nav-btn.skip {
            background: rgba(255, 217, 61, 0.2);
            border: 2px solid #ffd93d;
            color: #ffd93d;
        }

        .nav-btn.next {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .nav-btn:hover:not(:disabled) {
            transform: scale(1.02);
        }

        .nav-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Results Section */
        .results-section {
            text-align: center;
            padding: 35px;
        }

        .results-circle {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: conic-gradient(#38ef7d var(--percent), rgba(60,60,80,0.8) var(--percent));
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 auto 25px;
            position: relative;
        }

        .results-circle::before {
            content: '';
            position: absolute;
            width: 125px;
            height: 125px;
            background: #1a1a2e;
            border-radius: 50%;
        }

        .results-percent {
            position: relative;
            z-index: 1;
            font-size: 2.2em;
            font-weight: bold;
            color: #38ef7d;
        }

        .results-breakdown {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin-bottom: 25px;
        }

        .results-item .num {
            font-size: 1.8em;
            font-weight: bold;
        }

        .results-item .label {
            color: #999;
            font-size: 0.85em;
        }

        .results-item.correct .num { color: #38ef7d; }
        .results-item.wrong .num { color: #f5576c; }
        .results-item.skipped .num { color: #ffd93d; }

        .diagnostic-feedback {
            background: rgba(40, 40, 60, 0.7);
            border-radius: 12px;
            padding: 20px;
            text-align: left;
            margin-top: 20px;
        }

        .diagnostic-feedback h4 {
            color: #667eea;
            margin-bottom: 12px;
        }

        .diagnostic-feedback ul {
            list-style: none;
            padding: 0;
        }

        .diagnostic-feedback li {
            padding: 8px 0;
            padding-left: 22px;
            position: relative;
            color: #ccc;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .diagnostic-feedback li::before {
            content: '→';
            position: absolute;
            left: 0;
            color: #667eea;
        }

        .restart-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 14px 35px;
            border-radius: 10px;
            font-size: 1.1em;
            font-weight: 600;
            cursor: pointer;
            margin-top: 18px;
            transition: all 0.3s;
        }

        .restart-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }

        /* Hot Streak Tab */
        .hot-streak-intro {
            text-align: center;
            padding: 30px;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
            border-radius: 15px;
            margin-bottom: 20px;
        }

        .hot-streak-intro h3 {
            color: #667eea;
            font-size: 1.5em;
            margin-bottom: 15px;
        }

        .hot-streak-intro p {
            color: #ccc;
            line-height: 1.6;
            max-width: 600px;
            margin: 0 auto;
        }

        .hot-streak-rules {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .rule-badge {
            padding: 10px 20px;
            border-radius: 25px;
            font-size: 0.9em;
        }

        .rule-badge.bronze { background: rgba(205, 127, 50, 0.3); color: #cd7f32; border: 1px solid #cd7f32; }
        .rule-badge.silver { background: rgba(192, 192, 192, 0.3); color: #c0c0c0; border: 1px solid #c0c0c0; }
        .rule-badge.gold { background: rgba(255, 215, 0, 0.3); color: #ffd700; border: 1px solid #ffd700; }
        .rule-badge.diamond { background: rgba(185, 242, 255, 0.3); color: #89cff0; border: 1px solid #89cff0; }

        .start-streak-btn {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 12px;
            font-size: 1.2em;
            font-weight: bold;
            cursor: pointer;
            margin-top: 25px;
            transition: all 0.3s;
        }

        .start-streak-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 25px rgba(240, 147, 251, 0.4);
        }

        /* Educator's Corner Styles */
        .educator-section {
            margin-bottom: 25px;
        }

        .educator-section h3 {
            color: #667eea;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid rgba(102, 126, 234, 0.3);
        }

        .tip-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 15px;
        }

        .tip-card {
            background: rgba(40, 40, 60, 0.7);
            border-radius: 12px;
            padding: 20px;
            border-left: 4px solid;
            transition: transform 0.3s;
        }

        .tip-card:hover {
            transform: translateY(-3px);
        }

        .tip-card.purple { border-left-color: #764ba2; }
        .tip-card.green { border-left-color: #38ef7d; }
        .tip-card.pink { border-left-color: #f093fb; }
        .tip-card.blue { border-left-color: #667eea; }
        .tip-card.orange { border-left-color: #ffa726; }

        .tip-card h4 {
            color: #fff;
            margin-bottom: 10px;
            font-size: 1em;
        }

        .tip-card p {
            color: #b0b0b0;
